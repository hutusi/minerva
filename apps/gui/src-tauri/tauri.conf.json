{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minerva",
  "version": "0.3.0",
  "identifier": "com.hutusi.minerva",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Minerva",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:"
    }
  },
  "bundle": {
    "active": true,
    "externalBin": ["binaries/minerva", "binaries/rg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
